<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Anubhav | Portfolio</title>

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', sans-serif;
}

body {
    background: #0f172a;
    color: white;
}

/* Navbar */
header {
    display: flex;
    justify-content: space-between;
    padding: 20px 60px;
    background: #020617;
}

header h2 {
    color: #38bdf8;
}

nav a {
    margin-left: 20px;
    text-decoration: none;
    color: white;
}

/* Hero */
.hero {
    height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 20px;
}

.hero h1 {
    font-size: 48px;
}

.hero span {
    color: #38bdf8;
}

.hero p {
    margin: 20px 0;
}

.hero button {
    padding: 12px 25px;
    border: none;
    background: #38bdf8;
    color: black;
    cursor: pointer;
}

/* Sections */
.section {
    padding: 80px 60px;
    text-align: center;
    opacity: 0;
    transform: translateY(40px);
    transition: 0.8s;
}

.section.show {
    opacity: 1;
    transform: translateY(0);
}

.section h2 {
    margin-bottom: 40px;
    color: #38bdf8;
}

/* Cards */
.card {
    background: #1e293b;
    padding: 25px;
    border-radius: 10px;
    margin: auto;
    max-width: 700px;
}

.card p {
    margin: 15px 0;
}

/* Features */
.features {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px;
}

.feature-box {
    background: #1e293b;
    padding: 20px;
    width: 250px;
    border-radius: 10px;
}

/* Tech Stack */
.tech span {
    display: inline-block;
    background: #38bdf8;
    color: black;
    padding: 8px 15px;
    margin: 5px;
    border-radius: 20px;
}

/* Button */
.btn {
    display: inline-block;
    margin-top: 15px;
    padding: 10px 20px;
    background: #38bdf8;
    color: black;
    text-decoration: none;
    border-radius: 5px;
}

/* Footer */
footer {
    text-align: center;
    padding: 20px;
    background: #020617;
}
</style>
</head>

<body>

<header>
    <h2>Anubhav</h2>
    <nav>
        <a href="#">Home</a>
        <a href="#project">Project</a>
        <a href="#features">Features</a>
    </nav>
</header>

<section class="hero">
    <div>
        <h1>Hi, I'm <span>Anubhav</span> 👋</h1>
        <p>I build impactful tech solutions. Here’s one of my key projects.</p>
        <button onclick="scrollToProject()">View Project</button>
    </div>
</section>

<section class="section" id="project">
    <h2>Biodiversity Mapping Project 🌱</h2>

    <div class="card">
        <p>
            This project focuses on mapping biodiversity using modern technology 
            to help understand ecosystems better. It enables users to explore 
            species distribution and environmental data efficiently.
        </p>

        <p>
            The goal is to support environmental awareness, research, and conservation 
            efforts through an interactive platform.
        </p>

        <a href="https://github.com/rodhiya-anu/Biodiversity-Mapping-" target="_blank" class="btn">
            View on GitHub 🚀
        </a>
    </div>
</section>

<section class="section" id="features">
    <h2>Key Features</h2>

    <div class="features">
        <div class="feature-box">🌍 Interactive Mapping</div>
        <div class="feature-box">📊 Data Visualization</div>
        <div class="feature-box">🔍 Species Tracking</div>
        <div class="feature-box">📱 User-Friendly Interface</div>
    </div>
</section>

<section class="section">
    <h2>Tech Stack</h2>
    <div class="tech">
        <span>HTML</span>
        <span>CSS</span>
        <span>JavaScript</span>
        <span>GitHub</span>
    </div>
</section>

<footer>
    <p>© 2026 Anubhav | Portfolio</p>
</footer>

<script>
/* Smooth scroll */
function scrollToProject() {
    document.getElementById("project").scrollIntoView({
        behavior: "smooth"
    });
}

/* Scroll animation */
const sections = document.querySelectorAll(".section");

function reveal() {
    const trigger = window.innerHeight * 0.8;

    sections.forEach(sec => {
        const top = sec.getBoundingClientRect().top;

        if (top < trigger) {
            sec.classList.add("show");
        }
    });
}

window.addEventListener("scroll", reveal);
reveal();
</script>

</body>
</html>
